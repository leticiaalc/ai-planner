# =============================
# 🤖 MODO API
# =============================
def call_claude_api(prompt):
    response = client.messages.create(
        model="claude-3-5-sonnet-20240620",
        max_tokens=2000,
        temperature=0.3,
        messages=[
            {"role": "user", "content": prompt}
        ]
    )
    return response.content[0].text


# =============================
# 🧑‍💻 MODO MANUAL
# =============================
def call_claude_manual(prompt):
    print("\n📋 COPIE ESSE PROMPT E COLE NO CLAUDE:\n")
    print(prompt)

    print("\n✏️ Cole aqui o JSON de resposta:\n")
    print("Quando terminar, digite FIM em uma linha separada e aperte Enter:\n")

    lines = []

    while True:
        line = input()

        if line.strip().upper() == "FIM":
            break

        lines.append(line)
    return "\n".join(lines)


# =============================
# 📅 CRIAR EVENTOS
# =============================
def apply_calendar_actions(service, actions):
    for action in actions:
        acao = action.get("acao")

        if DEMO_MODE:
            if acao == "update":
                print(f"[DEMO] Atualizaria: {action['titulo']} | motivo: {action.get('motivo')}")
            elif acao == "create":
                print(f"[DEMO] Criaria: {action['titulo']} | motivo: {action.get('motivo')}")
            continue

        if acao == "update":
            update_event(service, action)

        elif acao == "create":
            create_single_event(service, action)


# =============================
# 🎮 MENU CLI
# =============================
def select_mode():
    print("\n=== 🤖 Selecione o modo ===")
    print("1 - Manual (Claude web)")
    print("2 - Automático (API)")

    choice = input("\nEscolha (1 ou 2): ")

    if choice == "1":
        return "manual"
    elif choice == "2":
        return "api"
    else:
        print("⚠️ Usando modo manual por padrão")
        return "manual"


# =============================
# 🚀 MAIN
# =============================
def main():
    print("entrou na main")
    mode = select_mode()

    print(f"\n🚀 Modo: {mode}")

    service = authenticate_google()
    events = get_events(service)

    prompt = build_prompt(events)

    if mode == "api":
        print("\n🤖 Chamando Claude via API...")
        response_text = call_claude_api(prompt)
    else:
        print("\n🧑‍💻 Modo manual...")
        response_text = call_claude_manual(prompt)

    print("\n📊 Resposta:\n", response_text)

    try:
        parsed = json.loads(response_text)
    except:
        print("❌ Erro ao converter JSON")
        return

    print("\n📅 Criando eventos...")
    create_single_event(service, parsed)

    print("\n✅ Finalizado!")


if __name__ == "__main__":
    print("chamando a main")
    main()